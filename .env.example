# ─────────────────────────────────────────────────────────────
# SayWhen — environment
# Copy to .env and fill in. EVERYTHING is optional: with no keys
# the app runs fully in SIMULATION mode (record your demo offline).
# ─────────────────────────────────────────────────────────────

# --- App ---
JWT_SECRET=change-me-to-a-long-random-string
DATABASE_URL=sqlite:///./data/negotiator.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Call mode: "simulation" (default) or "live" ---
CALL_MODE=simulation

# --- ElevenLabs (only needed for CALL_MODE=live) ---
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Caller agent (outbound negotiation calls)
ELEVENLABS_AGENT_ID=
# Conversational agent for the voice intake studio (falls back to ELEVENLABS_AGENT_ID)
ELEVENLABS_INTAKE_AGENT_ID=
# Phone number id the Caller Agent dials from (Convai › Phone numbers). Required for
# native outbound calls in CALL_MODE=live.
ELEVENLABS_PHONE_NUMBER_ID=
# Public URL where ElevenLabs/Twilio webhooks reach this backend (e.g. ngrok).
# Point the agent's post-call webhook at: {PUBLIC_BASE_URL}/api/integrations/elevenlabs/webhook
PUBLIC_BASE_URL=
# Optional shared secret. If set, the post-call webhook requires a matching
# x-webhook-secret header — blocks anyone from injecting events onto a campaign stream.
ELEVENLABS_WEBHOOK_SECRET=
# Shared secret guarding the live agent-tool webhooks (/api/agent-tools/*). Create the
# SAME value as a workspace secret named `agent_tools_secret` in ElevenLabs → Agents →
# Secrets, and reference it in each tool's Authorization header. If unset, the endpoints
# are open (fine for a keyless local demo; set it in any deployment the agents call).
AGENT_TOOLS_SECRET=

# --- Twilio (only needed for CALL_MODE=live) ---
# https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Google Places (optional: real vendor discovery). Falls back to seeded market. ---
GOOGLE_PLACES_API_KEY=

# --- Optional: nicer counterparty dialogue via an LLM. Falls back to templates. ---
# ANTHROPIC_API_KEY=
